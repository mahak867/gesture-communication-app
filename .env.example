# GestureTalk Environment Variables
# Copy this file to .env.local for local development
# cp .env.example .env.local

# ── Ollama (local AI inference) ───────────────────────────────────────────────
# URL of the locally running Ollama server.
# Default: http://localhost:11434 (Ollama's default port)
OLLAMA_URL=http://localhost:11434

# ── Google Gemma API (cloud fallback — optional) ──────────────────────────────
# Set this to use Google's Gemma API when Ollama is unavailable.
# Get a key at: https://aistudio.google.com/
GEMMA_API_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for absolute links and CORS).
# Example for Vercel: https://gesturetalk.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
