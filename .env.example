# ─── Gemma 4 via Ollama (required for live AI features) ─────────────────────
# Install: https://ollama.com → then: ollama pull gemma4
# Start:   ollama serve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Client-side (for status badge and autocomplete)
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_GEMMA_MODEL=gemma4

# ─── Demo mode (no Ollama needed — for judges without GPU) ──────────────────
# Append ?demo=1 to the URL to force demo mode with pre-recorded responses
# Demo mode auto-activates when Ollama is unreachable

# ─── Optional: PostHog analytics ────────────────────────────────────────────
# POSTHOG_API_KEY=phc_xxxx
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx

# ─── Optional: FHIR EHR export ──────────────────────────────────────────────
# FHIR_SERVER_URL=https://your-hospital.fhir.com/r4
# FHIR_BEARER_TOKEN=your_token

# ─── App URL (for Vercel deployment) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
